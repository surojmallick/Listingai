rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "mickeylamo247@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidListing(data) {
      return data.keys().hasAll(['userId', 'platform', 'title', 'description', 'createdAt']) &&
             data.userId is string &&
             data.platform in ['meesho', 'flipkart'] &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 10000 &&
             data.createdAt is string;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('geminiApiKey' in data) || data.geminiApiKey is string) &&
             (!('openaiApiKey' in data) || data.openaiApiKey is string) &&
             (!('preferredModel' in data) || data.preferredModel in ['gemini', 'openai']);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================
    match /listings/{listingId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId) && isValidListing(request.resource.data);
      allow update: if isOwner(resource.data.userId) && isValidListing(request.resource.data) && request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.uid == resource.data.uid;
      allow delete: if isAdmin();
    }
  }
}
